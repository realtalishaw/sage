# This prototype uses Groq directly from the browser on the application page.
# For production, move the request behind a server and keep the real key there.
VITE_GROQ_API_KEY=your_groq_api_key_here

# The default lightweight model is set in code, but this env var lets you swap
# models without editing source.
VITE_GROQ_MODEL=llama-3.1-8b-instant

# Optional media tools for the application chat.
# If omitted, Sage still works, but GIF / meme tool calls will quietly no-op.
VITE_GIPHY_API_KEY=your_giphy_api_key_here
VITE_IMGFLIP_USERNAME=your_imgflip_username_here
VITE_IMGFLIP_PASSWORD=your_imgflip_password_here

# Optional override for the hosted Stripe payment link used to skip the
# waitlist. The app appends client_reference_id and locked_prefilled_email at
# runtime so completed checkouts can be reconciled back to the Sage user.
VITE_SAGE_ANNUAL_PAYMENT_LINK=https://pay.joinsage.xyz/b/7sY3cwg1O8Jd1HPgqk6Vq0i
